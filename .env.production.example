# Production env example
# This file is for production-like deploys only.
# Fail fast expectations:
# - deploy must stop if any REQUIRED value is empty
# - deploy must stop if URLs still point to example.com
# - deploy must stop if secrets still contain CHANGE_ME
# - app runtime should bind loopback only behind reverse proxy

# =========================
# REQUIRED
# =========================
NODE_ENV=production
DATABASE_URL="postgresql://culi:CHANGE_ME@127.0.0.1:5432/culi_production?schema=public"

STOREFRONT_URL="https://shop.example.com"
ADMIN_URL="https://admin.example.com"
NEXTAUTH_URL="https://shop.example.com"

NEXTAUTH_SECRET="CHANGE_ME_LONG_RANDOM_SECRET"
ADMIN_SESSION_SECRET="CHANGE_ME_LONG_RANDOM_SECRET"

AUTH_TRUST_HOST="true"
COOKIE_SECURE="true"
TRUST_PROXY="true"

HOSTNAME="127.0.0.1"
STOREFRONT_PORT="3000"
ADMIN_PORT="3001"

# =========================
# OPTIONAL
# =========================
LOG_LEVEL="info"
